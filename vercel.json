{
  "version": 2,
  "builds": [
    { "src": "index-autolock.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/login.html" },
    { "src": "/(.*\\.html$)", "dest": "/$1" },
    { "src": "/(.*\\.js$)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index-autolock.js" }
  ]
}
