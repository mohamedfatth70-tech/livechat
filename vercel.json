{
  "version": 2,
  "builds": [
    { "src": "index-autolock.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/", "dest": "/public/login.html" },
    { "src": "/agent-dashboard-autolock.html", "dest": "/public/agent-dashboard-autolock.html" },
    { "src": "/auth.js", "dest": "/public/auth.js" },
    { "src": "/msal-browser.min.js", "dest": "/public/msal-browser.min.js" },
    { "src": "/(.*)", "dest": "/index-autolock.js" }
  ]
}
